# Example .env file for Discord Raid & Event Management Bot
# Copy this file to .env and fill in your actual values

# Discord Bot Token (get from Discord Developer Portal)
DISCORD_TOKEN=your-discord-bot-token-here

# Discord Channel IDs (right-click channel > Copy ID)
RAID_SCHEDULE_CHANNEL_ID=123456789012345678
INVENTORY_CHANNEL_ID=123456789012345678
OFFNIGHT_CHANNEL_ID=123456789012345678
SUGGESTIONS_CHANNEL_ID=123456789012345678
DISCORD_GUILD_ID=123456789012345678
DISCORD_RAID_CHANNEL_ID=123456789012345678
DISCORD_OFFNIGHT_CHANNEL_ID=123456789012345678

# Google Calendar and Sheets
GOOGLE_CALENDAR_ID=your-google-calendar-id@group.calendar.google.com
SUGGESTIONS_SHEET_ID=your-google-sheet-id

# Path to Google service account credentials (for calendar events)
GOOGLE_APPLICATION_CREDENTIALS=/app/config/google-service-account.json
# Path to Google credentials for suggestions (Google Sheets)
SUGGESTIONS_CREDENTIALS_PATH=/GOOGLE_CREDENTIALS.json

# (Optional) GitHub integration
GITHUB_TOKEN=your-github-token-here
GITHUB_REPO=your-github-username/your-repo-name
GITHUB_BRANCH=master

# Offnight event file path (relative to project root or container)
OFFNIGHT_FILE_PATH=assets/data/offnight.txt

# Raid file path (relative to project root or container)
RAID_FILE_PATH=assets/data/raids.txt

# (Optional) Disable inventory update notifications in Discord
# Set to 'true' to silence inventory processing messages (useful during development/debugging)
SILENT_INVENTORY_UPDATES=false

# Feature Toggles
# Set to 'false' to disable calendar functions (no Google Calendar updates)
ENABLE_CALENDAR_FUNCTIONS=true

# Set to 'false' to disable offnight.txt file operations (Discord thread processing still works)
ENABLE_OFFNIGHT_FILE_OPERATIONS=true

# Set to 'false' to disable Discord events creation and management
DISCORD_EVENTS_ENABLED=false

# Logging Configuration
# Log levels: error, warn, info, debug, verbose
# Or use --debug flag when running: npm run start:debug or npm run dev:debug
# LOG_LEVEL=debug

# Boss Respawn Tracker
# Target tracking channel (monitoring only, read-only, no command responses)
TARGET_TRACKING_CHANNEL_ID=1287222236314341497

# Boss data file path (OPTIONAL - defaults to data/default_bosses.json in project root)
# Only set this if you want to use a custom location for the boss data file
# BOSS_TRACKER_DATA_PATH=/path/to/custom/default_bosses.json

# Channels where /respawn and /lockout commands are allowed (comma-separated, optional)
# If not set, commands will work in ANY channel where bot has SendMessages permission
# Commands will NOT work in target-tracking channel (always blocked)
# Leave empty or omit to allow commands in all channels with proper permissions
BOSS_COMMAND_CHANNELS=123456789012345678,987654321098765432